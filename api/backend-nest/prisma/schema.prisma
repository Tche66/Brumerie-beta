generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  buyer
  seller
  livreur
}

enum UserTier {
  simple
  verified
  premium
}

enum RiskLevel {
  safe
  watch
  risk
  banned
}

enum ProductStatus {
  active
  sold
  paused
  draft
}

enum ProductCondition {
  new
  like_new
  second_hand
}

enum OrderStatus {
  initiated
  proof_sent
  confirmed
  ready
  picked
  delivered
  cod_pending
  cod_confirmed
  cod_delivered
  disputed
  cancelled
}

enum DeliveryType {
  delivery
  in_person
}

enum RatingRole {
  buyer_to_seller
  seller_to_buyer
  buyer_to_deliverer
  seller_to_deliverer
}

enum BoostStatus {
  pending
  active
  rejected
}

enum BoostDuration {
  h24
  h48
  j7
}

enum TrustReportStatus {
  pending
  reviewed
  dismissed
}

enum OfferStatus {
  pending
  accepted
  refused
  counter_offered
}

enum ReferralTier {
  first
  starter
  active
  influencer
  champion
  legend
  ambassador
}

model User {
  id                        String    @id @default(uuid())
  firebaseUid               String    @unique
  email                     String    @unique
  name                      String
  phone                     String?
  photoURL                  String?
  role                      UserRole  @default(buyer)
  tier                      UserTier  @default(simple)
  neighborhood              String?
  awAddressCode             String?
  bio                       String?
  hasPhysicalShop           Boolean   @default(false)
  managesDelivery           Boolean   @default(false)
  rating                    Float?
  reviewCount               Int       @default(0)
  contactCount              Int       @default(0)
  productCount              Int       @default(0)
  socialInstagram           String?
  socialTiktok              String?
  socialFacebook            String?
  socialTwitter             String?
  deliveryPriceSameZone     Int?
  deliveryPriceOtherZone    Int?
  deliveryPartnerName       String?
  deliveryPartnerPhone      String?
  deliveryPhotoURL          String?
  deliveryZones             String[]  @default([])
  deliveryBio               String?
  deliveryAvailable         Boolean   @default(false)
  totalDeliveries           Int       @default(0)
  totalEarnings             Int       @default(0)
  isVerified                Boolean   @default(false)
  verifiedUntil             DateTime?
  verifiedByAdmin           Boolean   @default(false)
  verifiedAt                DateTime?
  verificationPending       Boolean   @default(false)
  isPremium                 Boolean   @default(false)
  premiumUntil              DateTime?
  premiumByAdmin            Boolean   @default(false)
  premiumAt                 DateTime?
  advancePaymentAllowed     Boolean   @default(false)
  isBanned                  Boolean   @default(false)
  banReason                 String?
  banAt                     DateTime?
  riskLevel                 RiskLevel @default(safe)
  riskReportCount           Int       @default(0)
  lastActiveAt              DateTime?
  avgResponseTime           Int?
  dailyChatCount            Int       @default(0)
  lastChatReset             DateTime?
  followerCount             Int       @default(0)
  wishlistPublic            Boolean   @default(false)
  wishlistSlug              String?   @unique
  wishlistIds               String[]  @default([])
  followingSellerIds        String[]  @default([])
  recentlyViewedIds         String[]  @default([])
  bookmarkedProductIds      String[]  @default([])
  loyaltyPoints             Int       @default(0)
  loyaltyPointsUsed         Int       @default(0)
  referralCode              String?   @unique
  referredById              String?
  referralCount             Int       @default(0)
  referralBonusPublications Int       @default(0)
  referralBonusChats        Int       @default(0)
  referralFreeVerifiedUntil DateTime?
  delivererReferralCount    Int       @default(0)
  delivererReferralBonusAt  DateTime?
  delivererAccepted         Boolean   @default(false)
  shopThemeColor            String?
  shopBanner                String?
  shopSlogan                String?
  shopUsername              String?   @unique
  shopBio                   String?
  shopCategories            String[]  @default([])
  shopAddress               String?
  shopWhatsapp              String?
  shopInstagram             String?
  shopTiktok                String?
  shopClosedUntil           DateTime?
  shopClosedMessage         String?
  flashSaleActive           Boolean   @default(false)
  flashSaleLabel            String?
  flashSaleExpiry           DateTime?
  emailVerified             Boolean   @default(false)
  otpCode                   String?
  otpExpires                DateTime?
  trustScore                Float     @default(5.0)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  products             Product[]
  ordersAsBuyer        Order[]        @relation("BuyerOrders")
  ordersAsSeller       Order[]        @relation("SellerOrders")
  ordersAsDeliverer    Order[]        @relation("DelivererOrders")
  reviewsGiven         Review[]       @relation("ReviewsGiven")
  reviewsReceived      Review[]       @relation("ReviewsReceived")
  trustReportsFiled    TrustReport[]  @relation("TrustReporter")
  trustReportsReceived TrustReport[]  @relation("TrustReported")
  trustScore_rel       TrustScore?
  boosts               ProductBoost[]
  referralsOwned       Referral[]     @relation("ReferralOwner")
  referralsReceived    Referral[]     @relation("ReferralReferred")
  bookmarks            Bookmark[]
  searchAlerts         SearchAlert[]
  reposts              Repost[]
  productLikes         ProductLike[]
  productComments      ProductComment[]
  dettes               Dette[]
  comptaEntries        ComptaEntry[]
  clientsCarnet        ClientCarnet[]
  stories              Story[]

  @@map("users")
}

model Product {
  id                 String            @id @default(uuid())
  firebaseId         String?           @unique
  title              String
  description        String
  price              Int
  originalPrice      Int?
  condition          ProductCondition?
  quantity           Int               @default(1)
  category           String
  neighborhood       String
  neighborhoods      String[]          @default([])
  images             String[]          @default([])
  status             ProductStatus     @default(active)
  sellerId           String
  sellerName         String
  sellerPhone        String?
  sellerPhoto        String?
  sellerVerified     Boolean           @default(false)
  sellerPremium      Boolean           @default(false)
  viewCount          Int               @default(0)
  whatsappClickCount Int               @default(0)
  bookmarkCount      Int               @default(0)
  likeCount          Int               @default(0)
  commentCount       Int               @default(0)
  hideStats          Boolean           @default(false)
  promoPrice         Int?
  promoActiveFrom    DateTime?
  promoActiveUntil   DateTime?
  flashSaleActive    Boolean           @default(false)
  flashSaleScheduled Boolean           @default(false)
  flashSaleLabel     String?
  hasAcceptedOffer   Boolean           @default(false)
  taggedSellerIds    String[]          @default([])
  taggedSellerNames  String[]          @default([])
  delivererAccepted  Boolean           @default(false)
  delivererEnRoute   Boolean           @default(false)
  delivererGpsLink   String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  seller    User             @relation(fields: [sellerId], references: [firebaseUid])
  orders    Order[]
  boosts    ProductBoost[]
  reviews   Review[]
  likes     ProductLike[]
  comments  ProductComment[]
  reposts   Repost[]
  bookmarks Bookmark[]

  @@index([sellerId, status, createdAt])
  @@index([status, createdAt])
  @@index([category, status])
  @@index([neighborhood, status])
  @@index([likeCount, viewCount])
  @@map("products")
}

model ProductLike {
  id        String   @id @default(uuid())
  productId String
  userId    String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [firebaseUid])

  @@unique([productId, userId])
  @@map("product_likes")
}

model ProductComment {
  id           String   @id @default(uuid())
  productId    String
  userId       String
  userName     String
  userPhoto    String?
  userVerified Boolean  @default(false)
  text         String   @db.VarChar(500)
  parentId     String?
  photoUrl     String?
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [firebaseUid])

  @@map("product_comments")
}

model Repost {
  id                   String   @id @default(uuid())
  originalProductId    String
  originalProductTitle String
  originalProductImage String
  originalProductPrice Int
  originalSellerId     String
  originalSellerName   String
  reposterId           String
  reposterName         String
  reposterPhoto        String?
  comment              String
  createdAt            DateTime @default(now())

  product  Product @relation(fields: [originalProductId], references: [id], onDelete: Cascade)
  reposter User    @relation(fields: [reposterId], references: [firebaseUid])

  @@map("reposts")
}

model Order {
  id                             String       @id @default(uuid())
  firebaseId                     String?      @unique
  buyerId                        String
  buyerName                      String
  buyerPhoto                     String?
  sellerId                       String
  sellerName                     String
  sellerPhoto                    String?
  productId                      String
  productTitle                   String
  productImage                   String
  productPrice                   Int
  deliveryFee                    Int          @default(0)
  totalAmount                    Int
  brumerieFee                    Int          @default(0)
  sellerReceives                 Int
  paymentMethod                  String
  paymentPhone                   String
  paymentHolderName              String
  paymentWaveLink                String?
  proofScreenshotUrl             String?
  proofTransactionRef            String?
  proofSubmittedAt               DateTime?
  status                         OrderStatus  @default(initiated)
  deliveryType                   DeliveryType @default(delivery)
  isCOD                          Boolean      @default(false)
  sellerAuthorizedCashCollection Boolean      @default(false)
  sellerBlockedCashCollection    Boolean      @default(false)
  sellerCashAuthAt               DateTime?
  sellerReceivedCash             Boolean      @default(false)
  sellerReceivedCashAt           DateTime?
  delivererId                    String?
  delivererName                  String?
  delivererPhone                 String?
  delivererProposedBy            String?
  deliveryRequestedAt            DateTime?
  deliveryAcceptedAt             DateTime?
  deliveryPickedAt               DateTime?
  deliveryCode                   String?
  deliveryCodeGeneratedAt        DateTime?
  deliveryValidatedAt            DateTime?
  buyerAWCode                    String?
  buyerAWRepere                  String?
  buyerAWLatitude                Float?
  buyerAWLongitude               Float?
  buyerReviewed                  Boolean      @default(false)
  sellerReviewed                 Boolean      @default(false)
  buyerRatedDeliverer            Boolean      @default(false)
  sellerRatedDeliverer           Boolean      @default(false)
  reviewsUnlocked                Boolean      @default(false)
  disputeReason                  String?
  sellerBlocked                  Boolean      @default(false)
  reminderSentAt                 DateTime?
  autoDisputeAt                  DateTime?
  proofSentAt                    DateTime?
  createdAt                      DateTime     @default(now())
  updatedAt                      DateTime     @updatedAt

  buyer     User    @relation("BuyerOrders", fields: [buyerId], references: [firebaseUid])
  seller    User    @relation("SellerOrders", fields: [sellerId], references: [firebaseUid])
  deliverer User?   @relation("DelivererOrders", fields: [delivererId], references: [firebaseUid])
  product   Product @relation(fields: [productId], references: [id])
  reviews   Review[]

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([delivererId, status])
  @@index([createdAt])
  @@map("orders")
}

model Review {
  id                   String     @id @default(uuid())
  orderId              String
  productId            String
  productTitle         String
  fromUserId           String
  fromUserName         String
  fromUserPhoto        String?
  fromUserNeighborhood String?
  toUserId             String
  role                 RatingRole
  rating               Int
  comment              String
  createdAt            DateTime   @default(now())

  order    Order   @relation(fields: [orderId], references: [id])
  product  Product @relation(fields: [productId], references: [id])
  reviewer User    @relation("ReviewsGiven", fields: [fromUserId], references: [firebaseUid])
  reviewed User    @relation("ReviewsReceived", fields: [toUserId], references: [firebaseUid])

  @@map("reviews")
}

model TrustScore {
  id          String   @id @default(uuid())
  userId      String   @unique
  score       Float    @default(5.0)
  reviewCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [firebaseUid])

  @@index([score])
  @@map("trust_scores")
}

model TrustReport {
  id         String            @id @default(uuid())
  reporterId String
  reportedId String
  details    String            @db.VarChar(2000)
  status     TrustReportStatus @default(pending)
  adminNote  String?
  createdAt  DateTime          @default(now())
  reviewedAt DateTime?

  reporter User @relation("TrustReporter", fields: [reporterId], references: [firebaseUid])
  reported User @relation("TrustReported", fields: [reportedId], references: [firebaseUid])

  @@index([status, createdAt])
  @@index([reporterId, status])
  @@index([reportedId, createdAt])
  @@map("trust_reports")
}

model Story {
  id              String   @id @default(uuid())
  firebaseId      String?  @unique
  sellerId        String
  sellerName      String
  sellerPhoto     String?
  isVerified      Boolean  @default(false)
  imageUrl        String
  caption         String?
  productRefId    String?
  productRefTitle String?
  productRefPrice Int?
  views           String[] @default([])
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  seller User @relation(fields: [sellerId], references: [firebaseUid])

  @@index([sellerId, expiresAt])
  @@map("stories")
}

model ProductBoost {
  id              String        @id @default(uuid())
  productId       String
  productTitle    String?
  sellerId        String
  sellerName      String?
  duration        BoostDuration
  price           Int
  status          BoostStatus   @default(pending)
  waveRef         String?
  activatedAt     DateTime?
  activatedBy     String?
  rejectionReason String?
  startedAt       DateTime?
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())

  product Product @relation(fields: [productId], references: [id])
  seller  User    @relation(fields: [sellerId], references: [firebaseUid])

  @@index([status, expiresAt])
  @@index([sellerId])
  @@map("product_boosts")
}

model Referral {
  id            String        @id @default(uuid())
  ownerId       String
  referredId    String
  tier          ReferralTier?
  rewardClaimed Boolean       @default(false)
  claimedAt     DateTime?
  createdAt     DateTime      @default(now())

  owner    User @relation("ReferralOwner", fields: [ownerId], references: [firebaseUid])
  referred User @relation("ReferralReferred", fields: [referredId], references: [firebaseUid])

  @@unique([ownerId, referredId])
  @@index([ownerId])
  @@index([referredId])
  @@map("referrals")
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [firebaseUid])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("bookmarks")
}

model SearchAlert {
  id           String   @id @default(uuid())
  userId       String
  keyword      String
  category     String?
  neighborhood String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [firebaseUid])

  @@index([userId])
  @@map("search_alerts")
}

model Dette {
  id         String    @id @default(uuid())
  userId     String
  clientName String
  amount     Int
  note       String?
  paid       Boolean   @default(false)
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [firebaseUid])

  @@map("dettes")
}

model ComptaEntry {
  id        String   @id @default(uuid())
  userId    String
  type      String
  amount    Int
  label     String
  date      DateTime
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [firebaseUid])

  @@map("compta_entries")
}

model ClientCarnet {
  id         String   @id @default(uuid())
  userId     String
  clientName String
  phone      String?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [firebaseUid])

  @@map("clients_carnet")
}

model Report {
  id         String    @id @default(uuid())
  reporterId String
  targetId   String
  targetType String
  reason     String
  details    String?
  status     String    @default("pending")
  adminNote  String?
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  @@map("reports")
}

model AdminLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetId   String?
  targetType String?
  details    Json?
  createdAt  DateTime @default(now())

  @@map("admin_logs")
}

model DeadLetterQueue {
  id         String    @id @default(uuid())
  eventName  String
  payload    Json
  error      String
  retryCount Int       @default(0)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@map("dead_letter_queue")
}

model AiInteraction {
  id          String   @id @default(uuid())
  userId      String
  type        String
  input       Json
  output      Json
  productId   String?
  category    String?
  feedback    String?
  wasHelpful  Boolean?
  conversionHappened Boolean @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, type])
  @@index([type, createdAt])
  @@index([category, type])
  @@map("ai_interactions")
}
