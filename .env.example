# ── Firebase ─────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=brumerie-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=brumerie-app
VITE_FIREBASE_STORAGE_BUCKET=brumerie-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Admin ─────────────────────────────────────────────────────
# UID Firebase de l'administrateur (visible dans Firebase > Authentication)
VITE_ADMIN_UID=UID_FIREBASE_ICI

# ── Push Notifications (VAPID) ────────────────────────────────
# Générer sur https://vapidkeys.com/
VITE_VAPID_PUBLIC_KEY=BK...

# ── Variables Netlify (côté serveur, PAS dans .env) ───────────
# Ces variables se configurent dans Netlify > Site settings > Environment variables
# BREVO_API_KEY=xkeysib-...
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"brumerie-app",...}
# FIREBASE_API_KEY=AIza... (même valeur que VITE_FIREBASE_API_KEY)
